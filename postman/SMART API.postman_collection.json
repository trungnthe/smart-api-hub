    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = {};",
                  "const contentType = pm.response.headers.get('Content-Type') || '';",
                  "const isJson = contentType.includes('application/json');",
                  "",
                  "pm.test('Status code is successful', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Response time is under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "if (isJson) {",
                  "    pm.test('Response body is valid JSON', function () {",
                  "        pm.expect(function () {",
                  "            jsonData = pm.response.json();",
                  "        }).to.not.throw();",
                  "    });",
                  "",
                  "    pm.test('Login response includes success message and user data', function () {",
                  "        if (!Object.keys(jsonData).length) {",
                  "            jsonData = pm.response.json();",
                  "        }",
                  "        pm.expect(jsonData).to.be.an('object');",
                  "        pm.expect(jsonData).to.have.property('message');",
                  "        pm.expect(jsonData).to.have.property('user');",
                  "        pm.expect(jsonData.user).to.be.an('object');",
                  "        pm.expect(jsonData.user).to.have.property('email');",
                  "    });",
                  "",
                  "    pm.test('Login response contains an auth token', function () {",
                  "        if (!Object.keys(jsonData).length) {",
                  "            jsonData = pm.response.json();",
                  "        }",
                  "        const token = jsonData.token || jsonData.accessToken;",
                  "        pm.expect(token, 'Expected token or accessToken in response').to.be.a('string').and.not.empty;",
                  "    });",
                  "",
                  "    // Preserve and extend existing behavior: save returned token to collection variables",
                  "    const token = jsonData.token || jsonData.accessToken;",
                  "    if (token) {",
                  "        pm.collectionVariables.set('jwt_token', token);",
                  "        console.log('Saved latest token to collection variable jwt_token');",
                  "    }",
                  "}",
                  "",
                  "pm.test('Response has no server error', function () {",
                  "    pm.expect(pm.response.code).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
